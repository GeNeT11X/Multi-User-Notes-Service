# MongoDB connection string (MongoDB Atlas free tier recommended)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/notes-app?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace-with-a-long-random-secret-string
JWT_EXPIRES_IN=24h

# Server
PORT=3000
NODE_ENV=development

# Optional: override Swagger server URL for deployed instance
# BASE_URL=https://your-app.onrender.com
